<Window x:Class="KB18059_WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:igWPF="http://schemas.infragistics.com/xaml/wpf"
        xmlns:igDP="http://schemas.infragistics.com/xaml/wpf"
        xmlns:local="clr-namespace:KB18059_WpfApp1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <igWPF:XamDataGrid
            x:Name="xamDataGrid1"
            DataSource="{Binding}">

            <igWPF:XamDataGrid.FieldLayouts>
                <igWPF:FieldLayout IsDefault="true">
                    <igWPF:FieldLayout.Fields>
                        <igWPF:Field Name="ID" Width="200"/>
                        <igWPF:Field Name="Test1" Width="200"/>
                        <igWPF:Field Name="Test2" Width="200"/>
                    </igWPF:FieldLayout.Fields>

                    <igWPF:FieldLayout.SummaryDefinitions>
                        <igWPF:SummaryDefinition SourceFieldName="Test1">
                            <igWPF:SummaryDefinition.Calculator>
                                <local:NonEmptyCountCalculator />
                            </igWPF:SummaryDefinition.Calculator>
                        </igWPF:SummaryDefinition>
                    </igWPF:FieldLayout.SummaryDefinitions>
                </igWPF:FieldLayout>
            </igWPF:XamDataGrid.FieldLayouts>

        </igWPF:XamDataGrid>
    </Grid>
</Window>